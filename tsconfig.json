{
    "compilerOptions": {
        "outDir": "./dist",
        "sourceMap": true,
        "target": "esnext",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strict": false,
        "skipLibCheck": true,
        "lib": [
            "dom",
            "esnext"
        ],
        "types": [
            "node",
            "express",
            "multer",
            "jsonwebtoken",
            "bcryptjs",
            "nodemailer",
            "ejs",
            "morgan",
            "cookie-parser",
            "node-cron"
        ],
        "allowJs": true,
        "rootDir": ".",
        "removeComments": true,
        "moduleResolution": "node",
        "baseUrl": "./src",
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "typeRoots": [
            "./src/types",
            "./node_modules/@types"
        ],
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "./plugins/**/*",
        "./typings/**/*",
        "./dist/**/*"
    ]
}