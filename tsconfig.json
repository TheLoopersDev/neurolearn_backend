{
    "compilerOptions": {
        "outDir": "./dist",
        "types": ["node"],
        "sourceMap": true,
        "target": "esnext",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strict": false,
        "skipLibCheck": true,
        "lib": ["dom", "esnext"],
        "allowJs": true,
        "rootDir": ".",
        "removeComments": true,
        "moduleResolution": "node",
        "baseUrl": "./src",
        "paths": {
            "@/*": ["./*"]
        },
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "typeRoots": ["./src/types", "./node_modules/@types"],
        "types": ["node", "express"]
    },
    "include": ["./**/*"],
    "exclude": [
        "./plugins/**/*",
        "./typings/**/*",
        "./dist/**/*" // This is what fixed it!
    ]
}
